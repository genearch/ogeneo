---
interface Props { current: string; }
const { current } = Astro.props;
const chips = [
  { key: 'all', label: 'ALL', title: 'Everything' },
  { key: 'meta', label: null, icon: 'glasses', title: 'Through My Eyes' },
  { key: 'iphone', label: null, icon: 'camera', title: 'iPhone photos' },
  { key: 'thoughts', label: null, icon: 'star', title: 'Thoughts' },
  { key: 'experiences', label: null, icon: 'stack', title: 'Experiences' },
];
---
<div class="chips" role="tablist" aria-label="Filter feed">
  {chips.map((c) => (
    <a
      class:list={['chip', { active: current === c.key }]}
      href={c.key === 'all' ? '/' : `/?filter=${c.key}`}
      title={c.title}
      role="tab"
      aria-selected={current === c.key}
    >
      {c.label && <span class="label">{c.label}</span>}
      {c.icon === 'glasses' && (
        <svg viewBox="0 0 34 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="9" cy="8" r="6"/><circle cx="25" cy="8" r="6"/><path d="M15 8h4M1 6l2-2M33 6l-2-2"/></svg>
      )}
      {c.icon === 'camera' && (
        <svg viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="5" width="20" height="13" rx="2.5"/><path d="M8 5l1.6-2.4h4.8L16 5"/><circle cx="12" cy="11.5" r="3.6"/></svg>
      )}
      {c.icon === 'star' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 3l2.2 5.4L20 9l-4.4 3.8L17 19l-5-3.2L7 19l1.4-6.2L4 9l5.8-.6z"/></svg>
      )}
      {c.icon === 'stack' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M7 8V6h10v2M9 6V4h6v2"/></svg>
      )}
    </a>
  ))}
</div>

<style>
  .chips { display: flex; gap: 10px; margin: 4px 0 18px; overflow-x: auto; padding-bottom: 4px; }
  .chip {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 52px; height: 33px; padding: 0 14px;
    border-radius: 999px;
    border: 1px solid var(--card-edge);
    color: var(--text-dim);
    flex: 0 0 auto;
  }
  .chip svg { width: 24px; height: 16px; }
  .chip .label { font-size: 12.5px; letter-spacing: 0.12em; font-weight: 600; }
  .chip.active { background: var(--burgundy); border-color: var(--burgundy-bright); color: var(--text); }
  .chip:hover { border-color: var(--gold); color: var(--gold); }
</style>
