---
interface Props { current: string; }
const { current } = Astro.props;
---
<div class="chips" role="tablist" aria-label="Filter feed">
  <a class="home-glyph" href="/" title="Home" aria-label="Home">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 11.5 12 4l9 7.5V20a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z"/></svg>
  </a>
  <a class:list={['chip', { active: current === 'all' }]} href="/" role="tab" aria-selected={current === 'all'}>
    <span class="label">All Moments</span>
  </a>
  <a class:list={['chip', { active: current === 'meta' }]} href="/?filter=meta" role="tab" aria-selected={current === 'meta'} title="Meta glasses captures">
    <svg viewBox="0 0 34 16" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="9" cy="8" r="6"/><circle cx="25" cy="8" r="6"/><path d="M15 8h4M1 6l2-2M33 6l-2-2"/></svg>
    <span class="label">Through My Eyes</span>
  </a>
  <a class:list={['chip', { active: current === 'iphone' }]} href="/?filter=iphone" role="tab" aria-selected={current === 'iphone'}>
    <svg viewBox="0 0 24 20" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="5" width="20" height="13" rx="2.5"/><path d="M8 5l1.6-2.4h4.8L16 5"/><circle cx="12" cy="11.5" r="3.6"/></svg>
    <span class="label">Photograph</span>
  </a>
  <a class:list={['chip', { active: current === 'thoughts' }]} href="/?filter=thoughts" role="tab" aria-selected={current === 'thoughts'} title="Thoughts">
    <svg viewBox="0 0 32 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 4l1.6 3.9L26 8.3l-3.2 2.7 1 4.4-3.8-2.3-3.8 2.3 1-4.4L14 8.3l4.4-.4z"/><path d="M12 14 4 20M10 11 2 16" stroke-linecap="round"/></svg>
    <span class="label">Comet</span>
  </a>
  <a class:list={['chip', { active: current === 'experiences' }]} href="/?filter=experiences" role="tab" aria-selected={current === 'experiences'}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M7 8V6h10v2M9 6V4h6v2"/></svg>
    <span class="label">Experience</span>
  </a>
</div>

<style>
  .chips { display: flex; align-items: center; gap: 10px; margin: 4px 0 20px; overflow-x: auto; padding-bottom: 4px; scrollbar-width: none; }
  .chips::-webkit-scrollbar { display: none; }
  .home-glyph { color: var(--text-dim); flex: 0 0 auto; display: inline-flex; padding: 4px; }
  .home-glyph svg { width: 20px; height: 20px; }
  .home-glyph:hover { color: var(--gold); }
  .chip {
    display: inline-flex; align-items: center; gap: 8px;
    height: 36px; padding: 0 16px;
    border-radius: 999px;
    border: 1px solid var(--card-edge);
    color: var(--text-dim);
    flex: 0 0 auto;
  }
  .chip svg { width: 22px; height: 15px; }
  .chip .label { font-size: 12px; letter-spacing: 0.14em; font-weight: 600; text-transform: uppercase; white-space: nowrap; }
  .chip.active { background: var(--burgundy); border-color: var(--burgundy-bright); color: var(--text); }
  .chip:hover { border-color: var(--gold); color: var(--gold); }
  @media (max-width: 720px) {
    .chip { height: 33px; padding: 0 13px; }
    .chip .label { font-size: 11px; }
  }
</style>
