---
// Small "Currently Wandering 📍" line; the pin is the easter egg.
interface Weather { tempC: number; tempF: number; emoji: string; }
interface Stats { days: number; miles: number | null; moments: number; homePlace: string | null; }
interface Props {
  wandering: { place: string; note?: string; since?: string; country?: string; timezone?: string };
  weather?: Weather | null;
  stats?: Stats | null;
}
const { wandering, weather = null, stats = null } = Astro.props;

const flag = wandering.country && /^[A-Za-z]{2}$/.test(wandering.country)
  ? String.fromCodePoint(...[...wandering.country.toUpperCase()].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65))
  : null;
---
<div class="wander-line" id="wander-line" data-tz={wandering.timezone ?? ''}>
  <span class="wl-label">Currently wandering</span>
  <button class="pin" id="wander-pin" aria-label="Where is Gene right now?" aria-expanded="false" title="Psst. Click the pin.">
    📍
  </button>

  <div class="pop" id="wander-pop" hidden>
    <p class="place">{flag && <span class="flag">{flag}</span>}{wandering.place}</p>
    {wandering.note && <p class="note muted">{wandering.note}</p>}
    <p class="strip muted">
      {weather && <span>{weather.emoji} {weather.tempF}°F ({weather.tempC}°C)</span>}
      <span class="clock" id="wander-clock"></span>
    </p>
    {stats && (
      <div class="stats">
        <p><strong>{stats.days}</strong> day{stats.days === 1 ? '' : 's'} here</p>
        {stats.miles != null && <p><strong>{stats.miles.toLocaleString()}</strong> miles from {stats.homePlace ?? 'home'}</p>}
        <p><strong>{stats.moments}</strong> moment{stats.moments === 1 ? '' : 's'} since arriving</p>
      </div>
    )}
  </div>
</div>

<script>
  const line = document.getElementById('wander-line');
  const pin = document.getElementById('wander-pin');
  const pop = document.getElementById('wander-pop');
  const clock = document.getElementById('wander-clock');
  if (line && pin && pop) {
    const tz = line.dataset.tz || undefined;
    const tick = () => {
      if (!clock) return;
      try {
        clock.textContent = new Date().toLocaleTimeString('en-US', {
          hour: 'numeric', minute: '2-digit', timeZone: tz,
        });
      } catch { clock.textContent = ''; }
    };
    tick();
    setInterval(tick, 15000);

    pin.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = pop.hidden;
      pop.hidden = !open;
      pin.setAttribute('aria-expanded', String(open));
      pin.classList.toggle('dropped', open);
    });
    document.addEventListener('click', (e) => {
      if (!pop.hidden && !pop.contains(e.target as Node)) {
        pop.hidden = true;
        pin.setAttribute('aria-expanded', 'false');
        pin.classList.remove('dropped');
      }
    });
  }
</script>

<style>
  .wander-line {
    position: relative;
    display: flex; align-items: center; justify-content: flex-end; gap: 7px;
    margin: 0 2px 10px;
  }
  .wl-label {
    font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--gold);
  }
  .pin {
    background: none; border: none; cursor: pointer;
    font-size: 17px; line-height: 1; padding: 4px;
    transition: transform 0.18s ease;
  }
  .pin:hover { transform: translateY(-2px) rotate(-8deg); }
  .pin.dropped { transform: translateY(1px); }
  .pop {
    position: absolute; top: calc(100% + 8px); right: 0; z-index: 20;
    width: min(320px, 88vw);
    background: linear-gradient(135deg, var(--card-thought), color-mix(in srgb, var(--burgundy) 32%, var(--card)));
    border: 1px solid color-mix(in srgb, var(--burgundy-bright) 55%, var(--card-edge));
    border-radius: 14px;
    padding: 16px 18px;
    box-shadow: 0 12px 34px rgba(0,0,0,0.55);
  }
  .place { margin: 0; font-family: var(--display); font-size: 24px; font-weight: 500; color: var(--text); }
  .flag { margin-right: 9px; }
  .note { margin: 3px 0 0; font-size: 15px; }
  .strip { margin: 10px 0 0; display: flex; justify-content: space-between; gap: 12px; font-size: 14px; }
  .stats { border-top: 1px solid color-mix(in srgb, var(--burgundy-bright) 35%, transparent); margin-top: 12px; padding-top: 10px; }
  .stats p { margin: 3px 0 0; font-size: 14.5px; color: var(--text-dim); }
  .stats strong { color: var(--gold); font-weight: 600; }
</style>
