---
import { imgUrl } from '../lib/cloudinary';
interface Props {
  hero?: { title?: string; sub?: string; image_public_id?: string } | null;
  cloudName?: string;
}
const { hero = null, cloudName } = Astro.props;
const title = hero?.title ?? 'A personal glimpse\ninto my life.';
const sub = hero?.sub ?? 'The world through my eyes. My thoughts along the way.';
const titleLines = title.split('\n');
---
<section class="hero">
  <div class="copy">
    <h1>{titleLines.map((line, i) => <>{i > 0 && <br />}{line}</>)}</h1>
    <p class="sub">{sub}</p>
    <div class="divider"><span></span><i></i><span></span></div>
  </div>
  {hero?.image_public_id ? (
    <div class="art photo">
      <img
        src={imgUrl(cloudName, hero.image_public_id, 'f_auto,q_auto,w_900,h_560,c_fill')}
        alt="" width="900" height="560" loading="eager"
      />
    </div>
  ) : (
  <div class="art" aria-hidden="true">
    <svg viewBox="0 0 420 260" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
      <!-- hillside -->
      <path d="M10 250 C 90 240, 150 225, 205 200 C 260 175, 330 165, 410 160" />
      <!-- cypress trees -->
      <path d="M60 245 C 52 220, 52 190, 60 165 C 68 190, 68 220, 60 245 Z M60 165 V 250" />
      <path d="M120 238 C 112 210, 112 178, 120 150 C 128 178, 128 210, 120 238 Z M120 150 V 244" />
      <path d="M330 170 C 323 148, 323 122, 330 100 C 337 122, 337 148, 330 170 Z M330 100 V 176" />
      <path d="M385 165 C 379 146, 379 124, 385 105 C 391 124, 391 146, 385 165 Z M385 105 V 170" />
      <!-- stacked village -->
      <path d="M160 200 h34 v-30 h-34 Z M164 170 h26 l-13 -14 Z" />
      <path d="M198 196 h30 v-26 h-30 Z M198 170 h30 v-8 h-30 Z" />
      <path d="M232 192 h34 v-34 h-34 Z M236 158 l13 -12 13 12" />
      <path d="M180 168 h28 v-24 h-28 Z M180 144 l14 -12 14 12" />
      <path d="M212 162 h26 v-22 h-26 Z" />
      <path d="M240 156 h30 v-26 h-30 Z M244 130 l11 -10 11 10" />
      <path d="M196 142 h24 v-20 h-24 Z M196 122 l12 -10 12 10" />
      <path d="M224 128 h26 v-22 h-26 Z M228 106 l9 -9 9 9" />
      <path d="M208 104 h20 v-18 h-20 Z M208 86 l10 -9 10 9" />
      <!-- tower -->
      <path d="M215 86 v-16 h6 v16 M212 70 h12 M214 70 l4 -8 4 8" />
      <!-- windows -->
      <path d="M170 185 h6 v8 h-6 Z M204 182 h5 v7 h-5 Z M244 172 h6 v8 h-6 Z M188 152 h5 v7 h-5 Z M250 138 h6 v7 h-6 Z M232 114 h5 v6 h-5 Z" stroke-width="1" />
    </svg>
  </div>
  )}
</section>

<style>
  .hero {
    display: flex; align-items: center; justify-content: space-between; gap: 30px;
    padding: 30px 8px 26px;
  }
  .copy { max-width: 560px; }
  h1 {
    font-family: var(--display); font-weight: 500;
    font-size: 52px; line-height: 1.08; margin: 0 0 14px;
  }
  .sub {
    font-family: var(--hand); font-size: 27px; color: var(--text-dim);
    margin: 0 0 20px;
  }
  .divider { display: flex; align-items: center; gap: 10px; max-width: 360px; }
  .divider span { flex: 1; height: 1px; background: color-mix(in srgb, var(--burgundy-bright) 60%, transparent); }
  .divider i { width: 7px; height: 7px; border-radius: 50%; background: var(--burgundy-bright); }
  .art { color: color-mix(in srgb, var(--text) 55%, transparent); flex: 0 0 400px; }
  .art svg { width: 100%; height: auto; }
  .art.photo img {
    width: 100%; height: auto; aspect-ratio: 900 / 560; object-fit: cover;
    border-radius: 16px; border: 1px solid var(--card-edge);
  }
  @media (max-width: 960px) { .art { flex-basis: 300px; } h1 { font-size: 42px; } }
  @media (max-width: 720px) {
    .hero { flex-direction: column; align-items: flex-start; gap: 4px; padding: 16px 4px 12px; }
    h1 { font-size: 31px; margin-bottom: 8px; }
    .sub { font-size: 21px; margin-bottom: 12px; }
    .divider { max-width: 240px; width: 100%; }
    .art { flex-basis: auto; width: 74%; align-self: flex-end; margin-top: -6px; }
  }
</style>
