---
import type { Thought } from '../lib/types';
interface Props { thought: Thought; context?: string | null; }
const { thought, context } = Astro.props;
const when = new Date(thought.created_at).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});
---
<div class="thought-card">
  <span class="star" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path d="M12 3l2.2 5.4L20 9l-4.4 3.8L17 19l-5-3.2L7 19l1.4-6.2L4 9l5.8-.6z" />
    </svg>
  </span>
  <p class="body">{thought.body}</p>
  <p class="meta muted">
    {context && <span>{context}</span>}
    <span>{when}</span>
  </p>
</div>

<style>
  .thought-card {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 10px;
  }
  .star { color: var(--gold); flex: 0 0 auto; }
  .star svg { width: 24px; height: 24px; }
  .body {
    margin: 0; flex: 1;
    font-family: var(--hand);
    font-size: 25px; line-height: 1.2;
    color: var(--text);
  }
  .meta {
    margin: 0; text-align: right; font-size: 13px;
    display: flex; flex-direction: column; gap: 2px; flex: 0 0 auto;
    max-width: 40%;
  }
  @media (min-width: 721px) {
    .body { font-size: 28px; }
    .meta { font-size: 14px; }
  }
</style>
