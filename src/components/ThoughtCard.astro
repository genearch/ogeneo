---
import type { Thought } from '../lib/types';
interface Props { thought: Thought; context?: string | null; }
const { thought, context } = Astro.props;
const when = new Date(thought.created_at).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});
---
<div class="thought-card">
  <span class="comet" aria-hidden="true">
    <svg viewBox="0 0 32 24" fill="none" stroke="currentColor" stroke-width="1.4">
      <path d="M20 4l1.6 3.9L26 8.3l-3.2 2.7 1 4.4-3.8-2.3-3.8 2.3 1-4.4L14 8.3l4.4-.4z" />
      <path d="M12 14 4 20M14 17l-5 4M10 11 2 16" stroke-linecap="round" />
    </svg>
  </span>
  <p class="body">{thought.body}</p>
  <div class="foot">
    <p class="meta muted">
      {context && <span>{context}</span>}
      <span>{when}</span>
    </p>
    <p class="sig">Gene</p>
  </div>
</div>

<style>
  .thought-card {
    display: flex; flex-direction: column;
    aspect-ratio: 1;
    background: var(--card-thought);
    border: 1px solid color-mix(in srgb, var(--burgundy) 40%, var(--card-edge));
    border-radius: 14px;
    padding: 15px 15px 12px;
    overflow: hidden;
  }
  .comet { color: var(--gold); margin-bottom: 8px; flex: 0 0 auto; }
  .comet svg { width: 32px; height: 24px; }
  .body {
    margin: 0; flex: 1; min-height: 0;
    font-family: var(--hand);
    font-size: 25px; line-height: 1.2;
    color: var(--text);
    overflow: hidden;
  }
  .foot { display: flex; align-items: flex-end; justify-content: space-between; gap: 8px; flex: 0 0 auto; }
  .meta { margin: 0; font-size: 12.5px; display: flex; flex-direction: column; gap: 1px; }
  .sig { margin: 0; font-family: var(--hand); font-size: 21px; color: var(--text-dim); }
  @media (max-width: 720px) {
    .thought-card { padding: 11px 11px 9px; border-radius: 12px; }
    .comet svg { width: 26px; height: 20px; }
    .body { font-size: 19px; }
    .sig { font-size: 17px; }
    .meta { font-size: 10.5px; }
  }
</style>
