---
import { imgUrl } from '../lib/cloudinary';
import type { Experience } from '../lib/types';
interface Props { experience: Experience; cloudName?: string; }
const { experience: e, cloudName } = Astro.props;
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
const range = fmt(e.start_at) === fmt(e.end_at) ? fmt(e.start_at) : `${fmt(e.start_at)} – ${fmt(e.end_at)}`;
---
<a class="exp-card" href={`/experiences/${e.id}`}>
  {e.cover_public_id && (
    <img src={imgUrl(cloudName, e.cover_public_id, 'f_auto,q_auto,w_640,h_640,c_fill')} alt={e.title} loading="lazy" width="640" height="640" />
  )}
  <span class="badge glyph" title="Experience">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M7 8V6h10v2M9 6V4h6v2"/></svg>
  </span>
  <div class="overlay">
    <p class="kicker">Experience · {range} · {e.moment_count ?? 0} moments</p>
    <p class="title">{e.title}</p>
  </div>
</a>

<style>
  .exp-card {
    position: relative;
    display: block;
    aspect-ratio: 1;
    background: var(--card);
    border: 1px solid color-mix(in srgb, var(--gold) 35%, var(--card-edge));
    border-radius: 14px; overflow: hidden;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .exp-card:hover { border-color: var(--gold); transform: translateY(-2px); }
  .exp-card img { width: 100%; height: 100%; object-fit: cover; }
  .badge { position: absolute; top: 10px; left: 10px; }
  .badge svg { width: 16px; height: 14px; }
  .overlay {
    position: absolute; inset: auto 0 0 0;
    padding: 34px 13px 11px;
    background: linear-gradient(to top, rgba(10,7,6,0.94) 0%, rgba(10,7,6,0.65) 55%, transparent 100%);
  }
  .kicker { margin: 0 0 3px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: color-mix(in srgb, var(--text-dim) 80%, #fff); }
  .title {
    margin: 0; font-family: var(--display); font-size: 21px; color: var(--gold); line-height: 1.15;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  @media (max-width: 720px) {
    .exp-card { border-radius: 12px; }
    .overlay { padding: 26px 10px 9px; }
    .kicker { font-size: 9.5px; }
    .title { font-size: 17px; }
  }
</style>
