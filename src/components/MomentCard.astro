---
import SourceGlyph from './SourceGlyph.astro';
import { imgUrl } from '../lib/cloudinary';
import type { Moment } from '../lib/types';

interface Props { moment: Moment; cloudName?: string; }
const { moment, cloudName } = Astro.props;

const captured = new Date(moment.captured_at);
const isToday = captured.toDateString() === new Date().toDateString();
const when = isToday
  ? captured.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })
  : captured.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<a class="moment-card" href={`/moments/${moment.id}`}>
  {moment.cloudinary_public_id && (
    <div class="thumb">
      <img
        src={imgUrl(cloudName, moment.cloudinary_public_id, 'f_auto,q_auto,w_640,h_640,c_fill')}
        alt={moment.caption ?? 'Moment'}
        loading="lazy"
        width="640" height="640"
      />
      <span class="badge"><SourceGlyph source={moment.source} /></span>
    </div>
  )}
  <div class="body">
    <p class="caption">{moment.caption ?? 'Untitled moment'}</p>
    <p class="meta muted">
      {moment.place && <span>{moment.place}</span>}
      <span>{when}</span>
    </p>
  </div>
</a>

<style>
  .moment-card {
    display: flex; flex-direction: column;
    background: var(--card);
    border: 1px solid color-mix(in srgb, var(--card-edge) 60%, transparent);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .moment-card:hover { border-color: var(--gold); transform: translateY(-2px); }
  .thumb { position: relative; }
  .thumb img { width: 100%; aspect-ratio: 1; object-fit: cover; }
  .badge { position: absolute; top: 10px; left: 10px; }
  .body { padding: 12px 14px 14px; display: flex; flex-direction: column; gap: 6px; flex: 1; }
  .caption { margin: 0; font-size: 18px; line-height: 1.32; }
  .meta { margin: auto 0 0; display: flex; flex-direction: column; gap: 1px; font-size: 13.5px; padding-top: 4px; }
  @media (max-width: 720px) {
    .moment-card { border-radius: 12px; }
    .badge { top: 7px; left: 7px; }
    .body { padding: 9px 10px 11px; gap: 4px; }
    .caption { font-size: 15px; }
    .meta { font-size: 12px; }
  }
</style>
