---
import SourceGlyph from './SourceGlyph.astro';
import { imgUrl } from '../lib/cloudinary';
import type { Moment } from '../lib/types';

interface Props { moment: Moment; cloudName?: string; }
const { moment, cloudName } = Astro.props;

const captured = new Date(moment.captured_at);
const now = new Date();
const isToday = captured.toDateString() === now.toDateString();
const when = isToday
  ? captured.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })
  : captured.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<a class="moment-card" href={`/moments/${moment.id}`}>
  {moment.cloudinary_public_id && (
    <div class="thumb">
      <img
        src={imgUrl(cloudName, moment.cloudinary_public_id, 'f_auto,q_auto,w_320,h_320,c_fill')}
        alt={moment.caption ?? 'Moment'}
        loading="lazy"
        width="320" height="320"
      />
      <span class="badge"><SourceGlyph source={moment.source} /></span>
    </div>
  )}
  <div class="body">
    <p class="caption">{moment.caption ?? 'Untitled moment'}</p>
    <p class="meta muted">
      {moment.place && <span class="place">{moment.place}</span>}
      <span class="when">{when}</span>
    </p>
  </div>
</a>

<style>
  .moment-card {
    display: flex; gap: 16px; align-items: center;
    background: var(--card);
    border: 1px solid color-mix(in srgb, var(--card-edge) 60%, transparent);
    border-radius: 12px;
    padding: 10px;
    transition: border-color 0.15s ease;
  }
  .moment-card:hover { border-color: var(--gold); }
  .thumb {
    position: relative; flex: 0 0 104px;
    border-radius: 9px; overflow: hidden;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 1; }
  .badge { position: absolute; top: 7px; left: 7px; }
  .body { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 5px; min-width: 0; padding-right: 6px; }
  .caption { margin: 0; font-size: 18.5px; line-height: 1.3; }
  .meta { margin: 0; display: flex; flex-direction: column; gap: 1px; font-size: 13.5px; }
  @media (min-width: 721px) {
    .moment-card { gap: 20px; padding: 12px; }
    .thumb { flex-basis: 150px; }
    .caption { font-size: 21px; }
    .meta { font-size: 14.5px; }
  }
</style>
