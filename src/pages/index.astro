---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import FilterChips from '../components/FilterChips.astro';
import MomentCard from '../components/MomentCard.astro';
import ThoughtCard from '../components/ThoughtCard.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import type { Env, Moment, Thought, Experience } from '../lib/types';

const env = Astro.locals.runtime.env as Env;
const filter = Astro.url.searchParams.get('filter') ?? 'all';
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1') || 1);
const PAGE_SIZE = 24;
const offset = (page - 1) * PAGE_SIZE;
const cloudName = env.CLOUDINARY_CLOUD_NAME;

let momentWhere = '';
if (filter === 'meta') momentWhere = `WHERE source = 'meta'`;
if (filter === 'iphone') momentWhere = `WHERE source = 'iphone'`;

const showMoments = filter !== 'thoughts' && filter !== 'experiences';
const showThoughts = filter === 'all' || filter === 'thoughts';
const showExperiences = filter === 'all' || filter === 'experiences';

const [momentsRes, thoughtsRes, experiencesRes, countRow, annivRes, heroRow] =
  await Promise.all([
    showMoments
      ? env.DB.prepare(`SELECT * FROM moments ${momentWhere} ORDER BY captured_at DESC LIMIT ${PAGE_SIZE + 1} OFFSET ${offset}`).all<Moment>()
      : Promise.resolve({ results: [] as Moment[] }),
    showThoughts
      ? env.DB.prepare(`SELECT * FROM thoughts ORDER BY created_at DESC LIMIT 12`).all<Thought>()
      : Promise.resolve({ results: [] as Thought[] }),
    showExperiences
      ? env.DB.prepare(
          `SELECT e.*, COUNT(m.id) AS moment_count,
                  (SELECT cloudinary_public_id FROM moments
                   WHERE experience_id = e.id AND cloudinary_public_id IS NOT NULL
                   ORDER BY captured_at ASC LIMIT 1) AS cover_public_id
           FROM experiences e LEFT JOIN moments m ON m.experience_id = e.id
           GROUP BY e.id ORDER BY e.start_at DESC LIMIT 8`
        ).all<Experience>()
      : Promise.resolve({ results: [] as Experience[] }),
    env.DB.prepare(`SELECT COUNT(*) AS n FROM moments`).first<{ n: number }>(),
    env.DB.prepare(
      `SELECT * FROM moments
       WHERE strftime('%m-%d', captured_at) = strftime('%m-%d', 'now')
         AND strftime('%Y', captured_at) < strftime('%Y', 'now')
       ORDER BY captured_at DESC LIMIT 1`
    ).first<Moment>(),
    env.DB.prepare(`SELECT value FROM settings WHERE key = 'hero'`).first<{ value: string }>(),
  ]);

let heroSettings: { title?: string; sub?: string; image_public_id?: string } | null = null;
try { heroSettings = heroRow ? JSON.parse(heroRow.value) : null; } catch { /* ignore */ }

const allMoments = momentsRes.results ?? [];
const hasMore = allMoments.length > PAGE_SIZE;
const moments = allMoments.slice(0, PAGE_SIZE);
const thoughts = thoughtsRes.results ?? [];
const experiences = experiencesRes.results ?? [];
const totalMoments = countRow?.n ?? 0;
const milestone = [10, 25, 50, 100, 250, 500, 1000].includes(totalMoments) ? totalMoments : null;

// Grid interleave: a thought after every 2 moments, an experience after every 5.
type FeedItem =
  | { kind: 'moment'; moment: Moment }
  | { kind: 'thought'; thought: Thought }
  | { kind: 'experience'; experience: Experience };
const feed: FeedItem[] = [];
if (filter === 'thoughts') {
  for (const t of thoughts) feed.push({ kind: 'thought', thought: t });
} else if (filter === 'experiences') {
  for (const e of experiences) feed.push({ kind: 'experience', experience: e });
} else {
  let ti = 0, ei = 0;
  moments.forEach((m, i) => {
    feed.push({ kind: 'moment', moment: m });
    if (filter === 'all' && page === 1 && (i + 1) % 2 === 0 && ti < thoughts.length) {
      feed.push({ kind: 'thought', thought: thoughts[ti++] });
    }
    if (filter === 'all' && page === 1 && (i + 1) % 5 === 0 && ei < experiences.length) {
      feed.push({ kind: 'experience', experience: experiences[ei++] });
    }
  });
}

const nextHref = `/?${filter === 'all' ? '' : `filter=${filter}&`}page=${page + 1}`;
---
<Layout active="home">
  {filter === 'all' && page === 1 && <Hero hero={heroSettings} cloudName={cloudName} />}

  <FilterChips current={filter} />

  {milestone && page === 1 && (
    <div class="wide milestone">
      <p>Journey milestone: this journal just passed <strong>{milestone}</strong> moments.</p>
    </div>
  )}

  {annivRes && filter === 'all' && page === 1 && (
    <div class="wide anniversary">
      <p class="kicker muted">On this day, {new Date(annivRes.captured_at).getFullYear()}</p>
    </div>
  )}

  <div class="grid">
    {annivRes && filter === 'all' && page === 1 && <MomentCard moment={annivRes} cloudName={cloudName} />}
    {feed.map((item) => (
      item.kind === 'moment' ? <MomentCard moment={item.moment} cloudName={cloudName} />
      : item.kind === 'thought' ? <ThoughtCard thought={item.thought} />
      : <ExperienceCard experience={item.experience} cloudName={cloudName} />
    ))}
  </div>

  {feed.length === 0 && (
    <p class="muted empty">Nothing here yet. The first Moment is the hardest.</p>
  )}

  {hasMore && (
    <div class="more">
      <a href={nextHref}>Load more moments
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m6 9 6 6 6-6"/></svg>
      </a>
    </div>
  )}
</Layout>

<style>
  .wide { margin-bottom: 16px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    align-items: stretch;
  }
  @media (max-width: 1020px) { .grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px) { .grid { grid-template-columns: repeat(2, 1fr); gap: 11px; } }
  .milestone {
    border: 1px solid var(--gold); border-radius: 14px; padding: 14px 18px;
    background: color-mix(in srgb, var(--gold) 8%, var(--card));
  }
  .milestone p { margin: 0; font-family: var(--display); font-size: 20px; }
  .anniversary .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 4px; }
  .empty { text-align: center; padding: 60px 0; }
  .more { display: flex; justify-content: center; margin: 30px 0 8px; }
  .more a {
    display: inline-flex; align-items: center; gap: 8px;
    border: 1px solid var(--card-edge); border-radius: 999px;
    padding: 12px 26px; color: var(--text-dim);
    font-size: 12.5px; letter-spacing: 0.16em; text-transform: uppercase;
  }
  .more a:hover { border-color: var(--gold); color: var(--gold); }
  .more svg { width: 16px; height: 16px; }
</style>
