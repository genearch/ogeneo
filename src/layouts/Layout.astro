---
interface Props {
  title?: string;
  active?: 'home' | 'map' | 'collections' | 'search' | 'about';
}
const { title = 'OGENEO', active = 'home' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Caveat:wght@500;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="wordmark" href="/">OGENEO</a>
        <nav class="top-nav" aria-label="Primary">
          <a href="/" class:list={[{ active: active === 'home' }]}>Home</a>
          <a href="/map" class:list={[{ active: active === 'map' }]}>Map</a>
          <a href="/experiences" class:list={[{ active: active === 'collections' }]}>Experiences</a>
          <a href="/about" class:list={[{ active: active === 'about' }]}>About</a>
        </nav>
        <form class="header-search" method="get" action="/search">
          <input type="search" name="q" placeholder="Search moments..." aria-label="Search moments" />
        </form>
        <a class="avatar" href="/about" aria-label="About Gene">
          <img src="/avatar.png" alt="Gene" width="76" height="76" />
        </a>
      </div>
    </header>

    <main class="page">
      <slot />
    </main>

    <nav class="tab-bar" aria-label="Primary mobile">
      <a href="/" class:list={[{ active: active === 'home' }]}>
        <svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5V20a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Home</span>
      </a>
      <a href="/map" class:list={[{ active: active === 'map' }]}>
        <svg viewBox="0 0 24 24"><path d="M12 21s-7-6.1-7-11a7 7 0 0 1 14 0c0 4.9-7 11-7 11z" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="10" r="2.4" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Map</span>
      </a>
      <a href="/add" class="add-btn" aria-label="Add a Moment">
        <svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </a>
      <a href="/experiences" class:list={[{ active: active === 'collections' }]}>
        <svg viewBox="0 0 24 24"><rect x="4" y="6" width="16" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M8 6V4h8v2" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Experiences</span>
      </a>
      <a href="/search" class:list={[{ active: active === 'search' }]}>
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="m16 16 5 5" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Search</span>
      </a>
    </nav>
  </body>
</html>

<style is:global>
  :root {
    --bg: #131010;
    --card: #1e1815;
    --card-thought: #2a1c1f;
    --card-edge: #2c221c;
    --text: #efe7dc;
    --text-dim: #99897b;
    --gold: #c9a468;
    --burgundy: #5d2233;
    --burgundy-bright: #8a3448;
    --serif: 'EB Garamond', Georgia, serif;
    --display: 'Cormorant Garamond', Georgia, serif;
    --hand: 'Caveat', cursive;
  }
  * { box-sizing: border-box; }
  html { background: var(--bg); }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.45;
    min-height: 100dvh;
  }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  input { font-family: var(--serif); }

  .site-header {
    position: sticky; top: 0; z-index: 10;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--card-edge);
  }
  .header-inner {
    max-width: 1180px; margin: 0 auto; padding: 14px 20px;
    display: flex; align-items: center; gap: 26px;
  }
  .wordmark {
    font-family: var(--display);
    font-size: 23px; font-weight: 500;
    letter-spacing: 0.3em; text-indent: 0.3em;
    color: var(--gold);
    flex: 0 0 auto;
  }
  .top-nav { display: flex; gap: 30px; font-size: 14px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-dim); }
  .top-nav a { padding-bottom: 5px; border-bottom: 2px solid transparent; }
  .top-nav a.active { color: var(--text); border-bottom-color: var(--burgundy-bright); }
  .top-nav a:hover { color: var(--gold); }
  .header-search { margin-left: auto; }
  .header-search input {
    background: var(--card); border: 1px solid var(--card-edge);
    border-radius: 999px; padding: 9px 18px; color: var(--text);
    font-size: 15px; width: 230px;
  }
  .header-search input:focus { outline: none; border-color: var(--gold); }
  .avatar {
    width: 38px; height: 38px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--gold) 55%, var(--card-edge));
    flex: 0 0 auto;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .page { max-width: 1180px; margin: 0 auto; padding: 18px 16px 104px; }

  .tab-bar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 10;
    display: none;
    align-items: flex-end;
    background: color-mix(in srgb, var(--bg) 94%, transparent);
    backdrop-filter: blur(10px);
    border-top: 1px solid var(--card-edge);
    padding: 8px 8px calc(8px + env(safe-area-inset-bottom));
  }
  .tab-bar a {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px;
    color: var(--text-dim); font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase;
  }
  .tab-bar a.active { color: var(--burgundy-bright); }
  .tab-bar svg { width: 22px; height: 22px; }
  .tab-bar .add-btn {
    flex: 0 0 62px;
    width: 54px; height: 54px; margin: 0 4px 6px; align-self: center;
    border-radius: 50%;
    background: var(--burgundy);
    border: 1px solid var(--burgundy-bright);
    color: var(--text);
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 14px rgba(0,0,0,0.45);
    transform: translateY(-8px);
  }
  .tab-bar .add-btn svg { width: 26px; height: 26px; }

  @media (max-width: 720px) {
    .top-nav, .header-search { display: none; }
    .tab-bar { display: flex; }
    .header-inner { justify-content: space-between; }
    .avatar { width: 34px; height: 34px; font-size: 17px; }
    .page { padding-bottom: 110px; }
  }

  /* Shared bits */
  .glyph {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 27px; border-radius: 7px;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border: 1px solid color-mix(in srgb, var(--card-edge) 60%, var(--gold) 40%);
    color: var(--gold);
  }
  .glyph svg { width: 18px; height: 13px; }
  .muted { color: var(--text-dim); }
</style>
