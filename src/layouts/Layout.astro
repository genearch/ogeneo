---
interface Props {
  title?: string;
  active?: 'home' | 'map' | 'collections' | 'search';
}
const { title = 'OGENEO', active = 'home' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Caveat:wght@500;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="wordmark" href="/">OGENEO</a>
        <nav class="top-nav" aria-label="Primary">
          <a href="/" class:list={[{ active: active === 'home' }]}>Home</a>
          <a href="/map" class:list={[{ active: active === 'map' }]}>Map</a>
          <a href="/experiences" class:list={[{ active: active === 'collections' }]}>Collections</a>
          <a href="/search" class:list={[{ active: active === 'search' }]}>Search</a>
        </nav>
      </div>
    </header>

    <main class="page">
      <slot />
    </main>

    <nav class="tab-bar" aria-label="Primary mobile">
      <a href="/" class:list={[{ active: active === 'home' }]}>
        <svg viewBox="0 0 24 24"><path d="M3 11.5 12 4l9 7.5V20a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Home</span>
      </a>
      <a href="/map" class:list={[{ active: active === 'map' }]}>
        <svg viewBox="0 0 24 24"><path d="M12 21s-7-6.1-7-11a7 7 0 0 1 14 0c0 4.9-7 11-7 11z" fill="none" stroke="currentColor" stroke-width="1.6"/><circle cx="12" cy="10" r="2.4" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Map</span>
      </a>
      <a href="/experiences" class:list={[{ active: active === 'collections' }]}>
        <svg viewBox="0 0 24 24"><rect x="4" y="6" width="16" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M8 6V4h8v2" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Collections</span>
      </a>
      <a href="/search" class:list={[{ active: active === 'search' }]}>
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="6" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="m16 16 5 5" stroke="currentColor" stroke-width="1.6"/></svg>
        <span>Search</span>
      </a>
    </nav>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0e0b09;
    --card: #1b1512;
    --card-edge: #2a211c;
    --text: #efe7dc;
    --text-dim: #9b8d80;
    --gold: #c9a468;
    --burgundy: #5d2233;
    --burgundy-bright: #7a2c42;
    --serif: 'EB Garamond', Georgia, serif;
    --display: 'Cormorant Garamond', Georgia, serif;
    --hand: 'Caveat', cursive;
  }
  * { box-sizing: border-box; }
  html { background: var(--bg); }
  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.5;
    min-height: 100dvh;
  }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }

  .site-header {
    position: sticky; top: 0; z-index: 10;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--card-edge);
  }
  .header-inner {
    max-width: 1060px; margin: 0 auto; padding: 14px 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .wordmark {
    font-family: var(--display);
    font-size: 30px; font-weight: 500;
    letter-spacing: 0.35em; text-indent: 0.35em;
    color: var(--gold);
  }
  .top-nav { display: flex; gap: 26px; font-size: 16px; color: var(--text-dim); }
  .top-nav a.active, .top-nav a:hover { color: var(--gold); }

  .page { max-width: 1060px; margin: 0 auto; padding: 24px 20px 96px; }

  .tab-bar {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 10;
    display: none;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
    border-top: 1px solid var(--card-edge);
    padding: 8px 8px calc(8px + env(safe-area-inset-bottom));
  }
  .tab-bar a {
    flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px;
    color: var(--text-dim); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
  }
  .tab-bar a.active { color: var(--burgundy-bright); }
  .tab-bar svg { width: 22px; height: 22px; }

  @media (max-width: 720px) {
    .top-nav { display: none; }
    .tab-bar { display: flex; }
    .header-inner { justify-content: center; }
    .wordmark { font-size: 26px; }
    .page { padding-bottom: 110px; }
  }

  /* Shared bits */
  .glyph {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 26px; border-radius: 7px;
    background: color-mix(in srgb, var(--bg) 55%, transparent);
    border: 1px solid var(--card-edge);
    color: var(--gold);
  }
  .glyph svg { width: 20px; height: 14px; }
  .muted { color: var(--text-dim); }
</style>
