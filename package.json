{
  "name": "ogeneo",
  "type": "module",
  "version": "0.33.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "db:migrate:local": "wrangler d1 execute ogeneo --local --file=./db/schema.sql",
    "db:seed:local": "wrangler d1 execute ogeneo --local --file=./db/seed.sql",
    "db:migrate": "wrangler d1 execute ogeneo --remote --file=./db/schema.sql",
    "db:seed": "wrangler d1 execute ogeneo --remote --file=./db/seed.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.0",
    "astro": "^5.12.0"
  },
  "devDependencies": {
    "wrangler": "^4.25.0"
  }
}
